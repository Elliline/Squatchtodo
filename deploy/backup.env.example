# /etc/squatchtodo/backup.env
#
# Sourced by the squatchtodo-backup-{hourly,daily,weekly}.sh scripts.
# Permissions should be 0640 (root:squatchtodo) — these targets are
# infrastructure paths, not credentials, but there's no reason to leave
# them world-readable.

# -- shared ---------------------------------------------------------------

# Where the hourly snapshots land locally. Used by all three scripts.
# SNAPSHOT_DIR=/var/lib/squatchtodo/snapshots

# How many hourly snapshots to keep on disk. 48 = two days of hourlies.
# HOURLY_RETENTION=48

# -- daily (NAS) ----------------------------------------------------------

# Where the daily rsync sends the snapshots. Examples:
#   NAS_TARGET="backup@nas.local:/volume1/backups/squatchtodo"
#   NAS_TARGET="/mnt/nas/squatchtodo"          # NFS-mounted on Halo
NAS_TARGET=""

# Extra rsync options for the NAS leg, e.g. -e 'ssh -p 2222' or --bwlimit=10M.
# RSYNC_OPTS_NAS=""

# -- weekly (Datto offsite) ----------------------------------------------

# Offsite destination. Same shape as NAS_TARGET — either a local path of a
# Datto-mounted share or an SSH spec.
DATTO_TARGET=""

# RSYNC_OPTS_DATTO=""
